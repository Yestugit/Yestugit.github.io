---
import { getSectionOverview } from "@utils/content-utils";
import { formatDateToYYYYMMDD } from "@utils/date-utils";
import { getPostUrlBySlug, url } from "@utils/url-utils";
import { Icon } from "astro-icon/components";

const learning = await getSectionOverview("learning");
const life = await getSectionOverview("life");

const sections = [
	{
		title: "学习札记",
		description: "技术学习、课程笔记、项目实践与踩坑记录。",
		url: "/learning/",
		icon: "material-symbols:auto-stories-outline-rounded",
		overview: learning,
	},
	{
		title: "生活随想",
		description: "阅读、游戏、日常经历和偶尔出现的想法。",
		url: "/life/",
		icon: "material-symbols:local-florist-outline-rounded",
		overview: life,
	},
];
---

<section class="mb-4 grid grid-cols-1 gap-4 md:grid-cols-2" aria-label="内容栏目">
	{sections.map((section, index) => {
		const latestPost = section.overview.posts[0];
		return (
			<article class="card-base section-entry onload-animation" style={`animation-delay: calc(var(--content-delay) + ${index * 50}ms);`}>
				<a href={url(section.url)} class="group block h-full px-6 py-5" aria-label={`进入${section.title}`}>
					<div class="flex items-start justify-between gap-4">
						<div class="min-w-0">
							<div class="mb-3 flex items-center gap-3">
								<div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-xl bg-[var(--btn-regular-bg)] text-[var(--primary)]">
									<Icon name={section.icon} class="text-2xl" />
								</div>
								<h2 class="text-xl font-bold text-90 group-hover:text-[var(--primary)]">{section.title}</h2>
							</div>
							<p class="leading-6 text-50">{section.description}</p>
						</div>
						<Icon name="material-symbols:arrow-forward-rounded" class="mt-2 shrink-0 text-2xl text-[var(--primary)] transition-transform group-hover:translate-x-1" />
					</div>

					<div class="mt-5 flex flex-wrap items-center gap-x-4 gap-y-2 border-t border-black/5 pt-4 text-sm text-50 dark:border-white/10">
						<span>{section.overview.posts.length} 篇文章</span>
						{section.overview.latestUpdated && <span>更新于 {formatDateToYYYYMMDD(section.overview.latestUpdated)}</span>}
					</div>
				</a>

				{latestPost && (
					<a href={getPostUrlBySlug(latestPost.slug)} class="latest-link" aria-label={`阅读最新文章：${latestPost.data.title}`}>
						<span class="shrink-0 text-xs font-semibold text-[var(--primary)]">最新</span>
						<span class="truncate text-sm font-medium text-75">{latestPost.data.title}</span>
					</a>
				)}
			</article>
		);
	})}
</section>

<style>
	.section-entry {
		@apply relative flex min-h-52 flex-col;
	}
	.latest-link {
		@apply mx-4 mb-4 flex items-center gap-2 rounded-xl bg-[var(--btn-regular-bg)] px-3 py-2 hover:bg-[var(--btn-regular-bg-hover)];
	}
</style>
